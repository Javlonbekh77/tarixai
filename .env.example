# Environment Variables for Tarixchi AI

# ==========================
# Primary AI Provider (Google Gemini)
# Get your key: https://aistudio.google.com/app/apikey
# ==========================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ==========================
# Fast Fallback (Groq - LLaMA based, very fast)
# Get your key: https://console.groq.com/keys
# ==========================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ==========================
# General Fallback (OpenRouter - routes to multiple free models)
# Get your key: https://openrouter.ai/keys
# ==========================
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# ==========================
# Local Fallback (Ollama - optional, runs on your machine)
# Install from: https://ollama.com/
# Run: ollama pull gemma3
# ==========================
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3

# ==========================
# Media generation: Uzbek voice (Muxlisa async TTS)
# ==========================
MUXLISA_API_KEY=
MUXLISA_TTS_ENDPOINT=https://service.muxlisa.uz/api/v1/async/tts
MUXLISA_TTS_SPEAKER=1
MUXLISA_TTS_WEBHOOK_URL=
MUXLISA_WEBHOOK_SECRET=
MEDIA_AUDIO_DIR=public/generated/audio

# Optional free-ish sync TTS fallback. Docs: https://eidosspeech.xyz/
EIDOS_TTS_API_KEY=
EIDOS_TTS_ENDPOINT=https://eidosspeech.xyz/api/v1/tts
EIDOS_TTS_VOICE=uz-UZ-SardorNeural

# Aisha AI Uzbek TTS fallback/template generator.
AISHA_API_KEY=
AISHA_TTS_MODEL=Gulnoza
AISHA_TTS_MOOD=Neutral
AISHA_TTS_SPEED=1.0

# ==========================
# Media generation: natural fallback voice
# ==========================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# ==========================
# Media generation: free/demo image fallback
# ==========================
POLLINATIONS_API_KEY=
POLLINATIONS_IMAGE_ENABLED=true
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_TTS_ENABLED=false
POLLINATIONS_TTS_VOICE=alloy

# ==========================
# Media generation: image fallbacks
# ==========================
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
HF_TOKEN=
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# ==========================
# Internet image search
# ==========================
OPENVERSE_CLIENT_ID=
OPENVERSE_CLIENT_SECRET=
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
IMAGE_SEARCH_MODE=search
IMAGE_SEARCH_CACHE_TTL_HOURS=168
