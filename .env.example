# Environment Variables for Tarixchi AI

# ==========================
# Primary AI Provider (Google Gemini)
# Get your key: https://aistudio.google.com/app/apikey
# ==========================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ==========================
# Fast Fallback (Groq - LLaMA based, very fast)
# Get your key: https://console.groq.com/keys
# ==========================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ==========================
# General Fallback (OpenRouter - routes to multiple free models)
# Get your key: https://openrouter.ai/keys
# ==========================
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# ==========================
# Local Fallback (Ollama - optional, runs on your machine)
# Install from: https://ollama.com/
# Run: ollama pull gemma3
# ==========================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
